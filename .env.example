# Copy this file to .env and fill in real values. Do NOT commit .env.

# Required for POST /diet (Gemini AI)
GEMINI_API_KEY=

# Required for POST /send-sms (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional: comma-separated list of origins allowed to call the API.
# Leave empty to only allow same-origin requests.
# Example: ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=

# Optional: port override (default 5000)
# PORT=5000
